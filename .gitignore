# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
ENV/

# Ansible
*.retry
.cache/

# Molecule
.molecule/
molecule/**/instance_config.yml
molecule/**/driver.yml

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Secrets (never commit plaintext)
*.vault
vault.yml
secrets.yml
.vault_pass
.vault_password
SECRETS_SETUP.md
.doppler.yaml

# SOPS age private keys (never commit)
*.age
keys.txt

# Note: SOPS-encrypted files (*.sops.yml) ARE safe to commit (values are ciphertext)

# Local inventory overrides
inventory/local/
inventory/*.local.yml
inventory/terraform_inventory.json

# Logs
*.log
logs/

# Temporary files
tmp/
*.tmp

# Private documentation (environment-specific, not for git)
.docs/

# Nix/direnv
.direnv/
